generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int             @id @default(autoincrement())
  email        String          @unique
  password     String
  role         Role
  departmentId Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  empno        String          @unique
  createdJobs  Job[]           @relation("CreatedBy")
  createdJobReports JobReport[] @relation("JobReportCreatedBy")
  assignedJobs JobAssignment[]
  messages     Message[]
  participants Participant[]
  profile      Profile?
  department   Department?     @relation(fields: [departmentId], references: [id])
}

model Profile {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  firstname String?
  lastname  String?
  phone     String?
  avatar    String?
  birthday  DateTime?
  address   String?
  gender    Gender? 
  user      User      @relation(fields: [userId], references: [id])
}

model Department {
  id    Int    @id @default(autoincrement())
  name  String @unique
  jobs  Job[]
  users User[]
}

model Job {
  id                 Int             @id @default(autoincrement())
  title              String
  description        String?
  departmentId       Int
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  createdById        Int
  end_available_at   DateTime?
  latitude           Float?
  location_name      String?
  longitude          Float?
  start_available_at DateTime?
  status             JobStatus?      @default(PENDING)
  createdBy          User            @relation("CreatedBy", fields: [createdById], references: [id])
  department         Department      @relation(fields: [departmentId], references: [id])
  assignment         JobAssignment[]
  images             JobImage[]
  reports            JobReport[]
}

model JobReport {
  status             JobStatus     @default(COMPLETED)
  start_time         DateTime?
  end_time           DateTime?
  detail             String?
  repair_operations  String?
  inspection_results String?
  summary            String?
  cus_sign           String?
  jobId              Int
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  id                 Int           @id @default(autoincrement())
  rejectReason       String?
   createdById        Int?
  job                Job?           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdBy          User?            @relation("JobReportCreatedBy", fields: [createdById], references: [id])
  images             ReportImage[]
}

model JobImage {
  url       String?
  publicId  String?
  jobId     Int
  createdAt DateTime @default(now())
  id        Int      @id @default(autoincrement())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ReportImage {
  id        Int       @id @default(autoincrement())
  url       String?
  publicId  String?
  reportId  Int
  createdAt DateTime  @default(now())
  report    JobReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model JobAssignment {
  id         Int            @id @default(autoincrement())
  jobId      Int
  userId     Int
  assignedAt DateTime       @default(now())
  role       AssignmentRole
  job        Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId, role])
}

model Conversation {
  id           Int           @id @default(autoincrement())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     Message[]
  participants Participant[]
}

model Participant {
  id             Int          @id @default(autoincrement())
  userId         Int
  conversationId Int
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime     @default(now())
  unreadCount    Int          @default(0)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

model Message {
  id             Int          @id @default(autoincrement())
  content        String
  createdAt      DateTime     @default(now())
  senderId       Int
  conversationId Int
  isRead         Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

enum Role {
  SUPERADMIN
  ADMIN
  SUPERVISOR
  TECHNICIAN
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  COMPLETED
  REJECTED
}

enum AssignmentRole {
  SUPERVISOR
  TECHNICIAN
}
enum Gender {
  MALE
  FEMALE
  OTHER
}