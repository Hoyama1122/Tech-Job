generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int             @id @default(autoincrement())
  email        String          @unique
  password     String
  role         Role
  departmentId Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  empno        String          @unique
  createdJobs  Job[]           @relation("CreatedBy")
  assignedJobs JobAssignment[]
  profile      Profile?
  department   Department?     @relation(fields: [departmentId], references: [id])
}

model Profile {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  firstname String?
  lastname  String?
  phone     String?
  avatar    String?
  birthday  DateTime?
  address   String?
  gender    String?
  user      User      @relation(fields: [userId], references: [id])
}

model Department {
  id    Int    @id @default(autoincrement())
  name  String @unique
  jobs  Job[]
  users User[]
}

model Job {
  id                 Int             @id @default(autoincrement())
  title              String
  description        String?
  departmentId       Int
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  createdById        Int
  end_available_at   DateTime?
  latitude           Float?
  longitude          Float?
  location_name      String?
  start_available_at DateTime?
  status             JobStatus?       @default(PENDING)
  createdBy          User            @relation("CreatedBy", fields: [createdById], references: [id])
  department         Department      @relation(fields: [departmentId], references: [id])
  assignment         JobAssignment[]
  images             JobImage[]
  reports            JobReport[]
}

model JobReport {
  id                 Int           @id @default(autoincrement())
  status             JobStatus     @default(COMPLETED)
  start_time         DateTime?
  end_time           DateTime?
  detail             String?
  repair_operations  String?
  inspection_results String?
  summary            String?
  cus_sign           String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  jobId              Int
  job                Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  images             ReportImage[]
}

model JobImage {
  id        Int      @id @default(autoincrement())
  url       String?
  publicId  String?
  jobId     Int
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ReportImage {
  id        Int       @id @default(autoincrement())
  url       String
  reportId  Int
  createdAt DateTime  @default(now())
  report    JobReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model JobAssignment {
  id         Int            @id @default(autoincrement())
  jobId      Int
  userId     Int
  assignedAt DateTime       @default(now())
  role       AssignmentRole
  job        Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId, role])
}

enum Role {
  SUPERADMIN
  ADMIN
  SUPERVISOR
  TECHNICIAN
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum AssignmentRole {
  SUPERVISOR
  TECHNICIAN
}
