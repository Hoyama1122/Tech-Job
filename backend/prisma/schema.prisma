generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int         @id @default(autoincrement())
  empno        String      @unique
  email        String      @unique
  password     String
  role         Role
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  profile      Profile?
  createdJobs  Job[]    @relation("CreatedBy")
  assignedJobs Job[]    @relation("AssignedTo")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Profile {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  firstname String?
  lastname  String?
  phone     String?
  avatar    String?
  gender    String?
  birthday  DateTime?
  address   String?
  user      User      @relation(fields: [userId], references: [id])
}

model Department {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
  jobs  Job[]
}

model Job {
  id                 Int         @id @default(autoincrement())
  title              String
  description        String?
  latitude           Float?
  longitude          Float?
  location_name      String?
  start_available_at DateTime?
  end_available_at   DateTime?
  Jobimage           String?
  status             JobStatus   @default(PENDING)
  departmentId       Int
  department         Department  @relation(fields: [departmentId], references: [id])
  createdById        Int
  createdBy          User        @relation("CreatedBy", fields: [createdById], references: [id])
  assignedToId       Int
  AssignedTo         User        @relation("AssignedTo", fields: [assignedToId], references: [id])
  reports            JobReport[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model JobReport {
  Id                 Int       @id @default(autoincrement())
  status             JobStatus @default(COMPLETED)
  start_time         DateTime?
  end_time           DateTime?
  detail             String?
  repair_operations  String?
  inspection_results String?
  summary            String?
  images             String?
  cus_sign           String?
  jobId              Int
  job                Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

enum Role {
  SUPERADMIN
  ADMIN
  SUPERVISOR
  TECHNICIAN
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum AssignmentRole {
  SUPERVISOR
  TECHNICIAN
}