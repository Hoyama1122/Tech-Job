generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                Int             @id @default(autoincrement())
  email             String          @unique
  password          String
  role              Role
  departmentId      Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  empno             String          @unique

  createdJobs       Job[]           @relation("CreatedBy")
  createdJobReports JobReport[]     @relation("JobReportCreatedBy")
  approvedReports   JobReport[]     @relation("JobReportApprovedBy")
  rejectedReports   JobReport[]     @relation("JobReportRejectedBy")

  jobAssignments    JobAssignment[]
  profile           Profile?
  location          TechnicianLocation?
  department        Department?     @relation(fields: [departmentId], references: [id])
  
  items             Item[]
  itemUsages        ItemUsage[]
}

model TechnicianLocation {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  latitude  Float
  longitude Float
  accuracy  Float?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  firstname String?
  lastname  String?
  phone     String?
  avatar    String?
  birthday  DateTime?
  address   String?
  gender    Gender?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Department {
  id    Int    @id @default(autoincrement())
  name  String @unique
  jobs  Job[]
  users User[]
}

model Job {
  id                 Int          @id @default(autoincrement())
  title              String
  description        String?
  departmentId       Int
  createdById        Int

  start_available_at DateTime?
  end_available_at   DateTime?

  latitude           Float?
  longitude          Float?
  location_name      String?

  status             JobStatus    @default(PENDING)

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  createdBy          User         @relation("CreatedBy", fields: [createdById], references: [id])
  department         Department   @relation(fields: [departmentId], references: [id])

  assignments        JobAssignment[]
  images             JobImage[]
  reports            JobReport[]

  itemUsages         ItemUsage[]
}

model JobReport {
  id                 Int              @id @default(autoincrement())
  jobId              Int
  createdById        Int

  status             JobReportStatus  @default(SUBMITTED)

  start_time         DateTime?
  end_time           DateTime?
  detail             String?
  repair_operations  String?
  inspection_results String?
  summary            String?
  cus_sign           String?
  rejectReason       String?

  submittedAt        DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  reviewedAt         DateTime?

  approvedById       Int?
  rejectedById       Int?

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  job                Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdBy          User             @relation("JobReportCreatedBy", fields: [createdById], references: [id])
  approvedBy         User?            @relation("JobReportApprovedBy", fields: [approvedById], references: [id])
  rejectedBy         User?            @relation("JobReportRejectedBy", fields: [rejectedById], references: [id])

  images             ReportImage[]
}

model JobImage {
  id        Int      @id @default(autoincrement())
  url       String?
  publicId  String?
  jobId     Int
  createdAt DateTime @default(now())

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ReportImage {
  id        Int       @id @default(autoincrement())
  url       String?
  publicId  String?
  reportId  Int
  createdAt DateTime  @default(now())

  report    JobReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model JobAssignment {
  id         Int            @id @default(autoincrement())
  jobId      Int
  userId     Int
  role       AssignmentRole
  assignedAt DateTime       @default(now())

  job        Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId, role])
}

enum Role {
  SUPERADMIN
  ADMIN
  SUPERVISOR
  TECHNICIAN
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  SUBMITTED
  APPROVED
  REJECTED
}

enum JobReportStatus {
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}

enum AssignmentRole {
  SUPERVISOR
  TECHNICIAN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Item {
  id          Int         @id @default(autoincrement())
  code        String      @unique
  name        String
  model       String?
  brand       String?
  type        ItemType
  quantity    Decimal     @default(0) @db.Decimal(12, 2)
  unit        String
  createdBy   Int?
  note        String?

  creator     User?       @relation(fields: [createdBy], references: [id])
  usages      ItemUsage[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model ItemUsage {
  id           Int       @id @default(autoincrement())
  itemId       Int
  userId       Int
  jobId        Int
  usedQuantity Decimal   @db.Decimal(12, 2)
  note         String?
  usedAt       DateTime  @default(now())

  item         Item      @relation(fields: [itemId], references: [id])
  user         User      @relation(fields: [userId], references: [id])
  job          Job       @relation(fields: [jobId], references: [id])

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum ItemType {
  EQUIPMENT
  MATERIAL
}